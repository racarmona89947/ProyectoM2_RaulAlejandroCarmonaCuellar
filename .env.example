PORT=3000 # puerto de conexion del servidor

DATABASE_URL= # cadena completa de conexion PostgreSQL, por ejemplo la que da Railway
PUBLIC_URL= # url publica de la API en Railway, por ejemplo https://tu-proyecto.up.railway.app
DB_HOST= # host de conexion con la base de datos, si no usas DATABASE_URL
DB_PORT= # puerto de conexion con la base de datos, si no usas DATABASE_URL
DB_NAME= # nombre de la base de datos, si no usas DATABASE_URL
DB_USER= # usuario de la base de datos, si no usas DATABASE_URL
DB_PASSWORD= # contraseña de la base de datos, si no usas DATABASE_URL
DB_MAX_CONNECT= # numero maximo de conexiones a la base de datos
DB_IDLETIMEOUT= # tiempo de espera de conexion inactiva a la base de datos
DB_CONNECTIONTIMEOUT= # tiempo de espera de conexion a la base de datos
